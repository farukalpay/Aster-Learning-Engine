* text=auto eol=lf

# Source and project metadata
*.c text eol=lf
*.cc text eol=lf
*.cpp text eol=lf
*.cxx text eol=lf
*.h text eol=lf
*.hh text eol=lf
*.hpp text eol=lf
*.hxx text eol=lf
*.m text eol=lf
*.mm text eol=lf
*.metal text eol=lf
*.cmake text eol=lf
CMakeLists.txt text eol=lf
*.md text eol=lf diff=markdown
*.txt text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf

# Windows entry points, if added later
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets and generated media
*.bin binary -eol
*.png binary -eol
*.jpg binary -eol
*.jpeg binary -eol
*.gif binary -eol
*.ico binary -eol
*.icns binary -eol
*.pdf binary -eol
*.ppm binary -eol
